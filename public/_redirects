# SPA Redirect Rules for Cloudflare Pages
# Redirect all routes to index.html for client-side routing
/*    /index.html   200

# API routes (if any) should be excluded
/api/*  /api/:splat  200

# Static assets should be served directly
/assets/*  /assets/:splat  200
/product-image/*  /product-image/:splat  200
/banners/*  /banners/:splat  200
/audio/*  /audio/:splat  200
/blog-thumbnail/*  /blog-thumbnail/:splat  200
