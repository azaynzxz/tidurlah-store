# Create a .gitignore file to exclude unnecessary files
cat > .gitignore << EOF
# Node modules
node_modules/

# Build files
dist/
build/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories
.idea/
.vscode/
*.swp
*.swo
EOF

# Google Apps Script files (sensitive)
# Archive
archive/

# Temporary binaries and spreadsheets
*.xlsx
*.exe
*.tar.gz
logo-idcard-lampung.jpg
logo_nono.jpeg
src/pages/Untitled-1.txt
scripts/test-supabase.ts
scripts/test-anon.ts